# Production deployment example. Do not commit real secrets.
#
# Local `.env.example` keeps public-network smoke defaults for development convenience.
# Production and company intranet deployments must keep DreamMaker as the default
# music and Image 2 backend unless a temporary exception is explicitly approved.

SPRING_PROFILES_ACTIVE=prod
YANYUN_ENV=production

MUSIC_PROVIDER=suno
SUNO_BACKEND=dreammaker
IMAGE_PROVIDER=image2
IMAGE2_BACKEND=dreammaker

DREAMMAKER_API_BASE_URL=https://api-all.dreammaker.netease.com
DREAMMAKER_ACCESS_KEY=
DREAMMAKER_SECRET_KEY=
DREAMMAKER_USER_ACCESS_TOKEN=
DREAMMAKER_REAL_CALLS_ENABLED=false

AGENT_REAL_CALLS_ENABLED=false
DEEPSEEK_REAL_CALLS_ENABLED=false
IMAGE_REAL_CALLS_ENABLED=false
YUNWU_REAL_CALLS_ENABLED=false

MUSIC_WORKFLOW_DISPATCH_MODE=outbox
WORKFLOW_OUTBOX_DISPATCHER_ENABLED=true
WORKFLOW_OUTBOX_DISPATCH_TARGET=temporal
TEMPORAL_SONG_PRODUCTION_WORKFLOW_MODE=legacy
TEMPORAL_TARGET=
TEMPORAL_NAMESPACE=
TEMPORAL_TASK_QUEUE=

COMPANY_ACCOUNT_ADAPTER_MODE=company
COMPANY_MODERATION_ADAPTER_MODE=company
COMPANY_QUOTA_ADAPTER_MODE=company
COMPANY_PUBLISH_ADAPTER_MODE=company
COMPANY_SHARE_ADAPTER_MODE=company
