# Local-only defaults. Do not put real provider keys or company credentials here.

YANYUN_ENV=local

MUSIC_API_PORT=8080
MUSIC_WORKER_PORT=8081
WEB_PORT=5173
RENDER_WORKER_PORT=3001

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=yanyun_music
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379

TEMPORAL_TARGET=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=song-production-local

MINIO_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET_YANYUN_WORKS=yanyun-works-local

OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=YanyunLocalAdmin123!

MUSIC_PROVIDER=mock
DREAMMAKER_API_BASE_URL=https://api-all.dreammaker.netease.com
DREAMMAKER_ACCESS_KEY=
DREAMMAKER_SECRET_KEY=
DREAMMAKER_USER_ACCESS_TOKEN=
DREAMMAKER_REAL_CALLS_ENABLED=false
DREAMMAKER_REQUEST_TIMEOUT=30s
DREAMMAKER_MAX_POLL_ATTEMPTS=60
DREAMMAKER_POLL_INTERVAL=2s
SUNO_MODEL=chirp-crow
MINIMAX_MODEL=minimax-music-2.6
MUSIC_WORKFLOW_DISPATCH_MODE=sync
WORKFLOW_OUTBOX_DISPATCHER_ENABLED=false
WORKFLOW_OUTBOX_DISPATCH_TARGET=local
WORKFLOW_OUTBOX_POLL_INTERVAL=5s
WORKFLOW_OUTBOX_BATCH_SIZE=5
WORKFLOW_OUTBOX_MAX_ATTEMPTS=3
WORKFLOW_OUTBOX_LOCK_TIMEOUT=60s
WORKFLOW_OUTBOX_RETRY_DELAY=10s
DEEPSEEK_API_KEY=
IMAGE2_API_KEY=
COMPANY_ACCOUNT_ADAPTER_MODE=mock
COMPANY_MODERATION_ADAPTER_MODE=mock
COMPANY_QUOTA_ADAPTER_MODE=mock
COMPANY_PUBLISH_ADAPTER_MODE=mock
COMPANY_SHARE_ADAPTER_MODE=mock
